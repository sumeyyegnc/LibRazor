@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<section class="content-section bg-light" id="about">
    <div class="container px-4 px-lg-5 text-center">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-lg-10">
                <h2>KİTAPLAR DÜNYASINA HOŞ GELDİNİZ</h2>
                <p class="lead mb-5">
                 
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Services-->
<section class="content-section bg-primary text-white text-center" id="services">
    <div class="container px-4 px-lg-5">
        <div class="content-section-heading">
            <h3 class="text-secondary mb-0">Kitaplar</h3>
            <h2 class="mb-5">Kitap Türleri</h2>
        </div>
        <div class="row gx-4 gx-lg-5">
            <div class="col-lg-3 col-md-6 mb-5 mb-lg-0">
                <span class="service-icon rounded-circle mx-auto mb-3"><i class="icon-screen-smartphone"></i></span>
                <h4><strong>Roman</strong></h4>
                <p class="text-faded mb-0">Duygular ve olaylar üzerine kurulu hikayeler.</p>
            </div>
            <div class="col-lg-3 col-md-6 mb-5 mb-lg-0">
                <span class="service-icon rounded-circle mx-auto mb-3"><i class="icon-pencil"></i></span>
                <h4><strong>Şiir</strong></h4>
                <p class="text-faded mb-0">Duyguların estetik bir dille anlatımı.</p>
            </div>
            <div class="col-lg-3 col-md-6 mb-5 mb-md-0">
                <span class="service-icon rounded-circle mx-auto mb-3"><i class="icon-like"></i></span>
                <h4><strong>Biyografi</strong></h4>
                <p class="text-faded mb-0">
                    Ünlü yazar ve kişilerin hayat hikayeleri.
                </p>
            </div>
            <div class="col-lg-3 col-md-6">
                <span class="service-icon rounded-circle mx-auto mb-3"><i class="icon-mustache"></i></span>
                <h4><strong>Klasikler</strong></h4>
                <p class="text-faded mb-0">Zamansız ve dünya edebiyatının temel eserleri.</p>
            </div>
        </div>
    </div>
</section>

<!-- Callout-->


<!-- Portfolio-->
<section class="content-section" id="portfolio">
    <div class="container px-4 px-lg-5">
        <div class="content-section-heading text-center">
            <h3 class="text-secondary mb-0">Kitaplar</h3>
            <h2 class="mb-5">Önerilen Kitaplar</h2>
        </div>
        <div class="row gx-0">           
        
            <div class="col-lg-6">
                <a class="portfolio-item" href="">
                    <div class="caption">
                        <div class="caption-content">
                            <div class="h2">Sincaplarda Kitap Okur</div>
                            <p class="mb-0">Mesela Polisiye.</p>
                        </div>
                    </div>
                    <img class="img-fluid" src="assets/img/sincap.jpg" alt="..." />
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action-->
<section class="content-section bg-primary text-white">
    <div class="container px-4 px-lg-5 text-center">
        <h2 class="mb-4">Kitap okumak hayatı değiştirir...</h2>
        <a class="btn btn-xl btn-light me-4" href="">Oku</a>
    </div>
</section>

