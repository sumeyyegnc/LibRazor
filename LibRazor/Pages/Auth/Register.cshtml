@page
@model LibRazor.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Kayıt Ol</h2>
            
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success">@Model.SuccessMessage</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Ad Soyad</label>
                    <input type="text" class="form-control" name="adsoyad" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" name="email" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input type="password" class="form-control" name="sifre" required />
                </div>
                <button type="submit" class="btn btn-success w-100">Kayıt Ol</button>
            </form>
            
            <div class="mt-3 text-center">
                <p>Zaten bir hesabınız var mı? <a href="/Auth/Login">Giriş Yap</a></p>
            </div>
        </div>
    </div>
</div>
